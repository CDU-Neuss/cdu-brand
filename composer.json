{
  "name": "cdu-neuss/cdu-brand",
  "description": "CDU brand template components for Laravel (Blade), Twig, and Statamic (Antlers)",
  "version": "1.14.1",
  "type": "library",
  "license": "proprietary",
  "homepage": "https://github.com/CDU-Neuss/cdu-brand",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "illuminate/view": "^10.0 | ^11.0 | ^12.0 | ^13.0",
    "twig/twig": "^3.0",
    "pestphp/pest": "^4.0",
    "statamic/cms": "^6.0"
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:blade": "vendor/bin/pest --group=blade",
    "test:twig": "vendor/bin/pest --group=twig",
    "test:antlers": "vendor/bin/pest --group=antlers",
    "kitchen-sink:build": "npx @tailwindcss/cli -i tests/kitchen-sink/input.css -o tests/kitchen-sink/styles.css --minify",
    "kitchen-sink:serve": "php -S localhost:8080 tests/kitchen-sink/router.php",
    "kitchen-sink": [
      "@kitchen-sink:build",
      "@kitchen-sink:serve"
    ]
  },
  "autoload": {
    "psr-4": {
      "CduNeuss\\CduBrand\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/php/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "CduNeuss\\CduBrand\\Laravel\\CduBrandServiceProvider"
      ]
    }
  },
  "suggest": {
    "illuminate/support": "Required for Laravel Blade component auto-registration (^10.0 || ^11.0 || ^12.0 || ^13.0)",
    "twig/twig": "Required for Twig namespace registration (^3.0)",
    "statamic/cms": "Required for Antlers partial namespace registration (^4.0 || ^5.0 || ^6.0)"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "pixelfear/composer-dist-plugin": true
    }
  }
}
