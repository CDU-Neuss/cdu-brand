---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"figure"> {
  targetDate: string;
  event?: string;
  labels?: {
    days?: string;
    hours?: string;
    minutes?: string;
    seconds?: string;
  };
}

const defaultLabels = {
  days: "Days",
  hours: "Hours",
  minutes: "Minutes",
  seconds: "Seconds",
};

const { targetDate, event, labels, class: className, ...attrs } = Astro.props;
const mergedLabels = { ...defaultLabels, ...labels };
---

<figure class:list={["countdown", className]} aria-hidden="true" x-data={`countdown('${targetDate}')`} x-cloak {...attrs}>
  <div class="clock">
    <dl x-show="days > 0">
      <dd x-text="days">&nbsp;</dd>
      <dt>{mergedLabels.days}</dt>
    </dl>
    <div class="divider" x-show="days > 0">:</div>
    <dl x-show="hours > 0">
      <dd x-text="hours">&nbsp;</dd>
      <dt>{mergedLabels.hours}</dt>
    </dl>
    <div class="divider" x-show="hours > 0">:</div>
    <dl>
      <dd x-text="minutes">&nbsp;</dd>
      <dt>{mergedLabels.minutes}</dt>
    </dl>
    <div class="divider">:</div>
    <dl>
      <dd x-text="seconds">&nbsp;</dd>
      <dt>{mergedLabels.seconds}</dt>
    </dl>
  </div>
  {event && <figcaption>{event}</figcaption>}
</figure>

<script>
  import countdown from "../../js/countdown.js";

  Alpine.data("countdown", (targetDate: string) => countdown(targetDate));
</script>
