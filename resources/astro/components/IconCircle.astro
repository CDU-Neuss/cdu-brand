---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"figure"> {
  icon?: string;
  size?: "default" | "lg" | "xl" | "2xl";
  as?: "a" | "button" | "figure";
}

const { icon, size = "default", as: As = "figure", class: className, ...attrs } = Astro.props;
const circleClass =
  size === "lg" ? "icon-circle-lg" : size === "xl" ? "icon-circle-xl" : size === "2xl" ? "icon-circle-2xl" : "icon-circle";
---

<As class:list={[circleClass, className]} {...attrs}>
  {icon ? { icon } : <slot />}
</As>
