{#
  CDU Eye Catcher Circle Component

  Parameters:
    - class: additional CSS classes to merge onto the root element (default: '')
    - attr: extra HTML attributes string, rendered unescaped — must be trusted (default: '')

  Blocks:
    - content: text or elements inside the circle

  Usage:
    {% embed '@cdu/eye-catcher-circle.twig' %}
      {% block content %}<strong>New</strong><br>Feature{% endblock %}
    {% endembed %}
#}

{% set class = class|default('') %}
{% set attr = attr|default('') %}

<div class="{{ ['eye-catcher-circle', class]|join(' ')|trim }}" {{ attr|raw }}>
    {% block content %}{% endblock %}
</div>
