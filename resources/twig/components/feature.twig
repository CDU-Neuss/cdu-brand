{#
  CDU Feature Component

  Parameters:
    - title: feature heading (required)
    - icon: HTML string for the icon inside the icon-circle, rendered unescaped — must be trusted (optional)
    - class: additional CSS classes to merge onto the root element (default: '')
    - attr: extra HTML attributes string, rendered unescaped — must be trusted (default: '')

  Blocks:
    - content: feature description

  Usage:
    {% embed '@cdu/feature.twig' with { title: 'My Feature', icon: '<svg>…</svg>' } %}
      {% block content %}<p>Description here.</p>{% endblock %}
    {% endembed %}
#}

{% set icon = icon|default('') %}
{% set class = class|default('') %}
{% set attr = attr|default('') %}

<div class="{{ ['feature', class]|join(' ')|trim }}" {{ attr|raw }}>
    <div class="icon">
        <figure class="icon-circle">
            {{ icon|raw }}
        </figure>
    </div>
    <div class="content">
        <h5 class="title">{{ title }}</h5>
        {% block content %}{% endblock %}
    </div>
</div>
