{#
  CDU Linked Section Component

  Parameters:
    - title: section heading (required)
    - href: link URL (required)
    - link_text: custom link label (default: title value)
    - has_button: if true, renders gold button instead of link style (default: false)
    - class: additional CSS classes to merge onto the root element (default: '')
    - attr: extra HTML attributes string, rendered unescaped — must be trusted (default: '')
    - link_attr: extra HTML attributes string rendered on the link element — must be trusted (default: '')

  Blocks:
    - icon: optional icon inside the icon-circle
    - content: section body text

  Usage:
    {% embed '@cdu/linked-section.twig' with { title: 'Read more', href: '/page' } %}
      {% block icon %}<svg>…</svg>{% endblock %}
      {% block content %}<p>Teaser text here.</p>{% endblock %}
    {% endembed %}
#}

{% set link_text = link_text|default(title) %}
{% set has_button = has_button|default(false) %}
{% set class = class|default('') %}
{% set attr = attr|default('') %}
{% set link_attr = link_attr|default('') %}

<div class="{{ ['linked-section', has_button ? 'has-button' : '', class]|join(' ')|trim }}" {{ attr|raw }}>
    <div class="headline">
        <div class="icon">
            <figure class="icon-circle">
                {% block icon %}

                {% endblock %}
            </figure>
        </div>
        <h3 class="title">{{ title }}</h3>
    </div>
    <div class="content">
        {% block content %}

        {% endblock %}
    </div>
    <div class="link">
        <a href="{{ href }}" class="btn{{ has_button ? ' btn-gold' : ' btn-link' }}" {{ link_attr|raw }}>
            {{ link_text }}
            {% if not has_button %}
                {# Phosphor caret-right-bold #}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="1em" height="1em">
                    <path
                        d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"
                    />
                </svg>
            {% endif %}
        </a>
    </div>
</div>
