{#
  CDU Linked Section Component

  Parameters:
    - title: section heading (required)
    - href: link URL (required)
    - link_text: custom link label (default: title value)
    - has_button: if true, renders gold button instead of link style (default: false)
    - icon: HTML string for the icon inside the icon-circle (optional)

  Blocks:
    - content: section body text

  Usage:
    {% embed '@cdu/linked-section.twig' with { title: 'Read more', href: '/page', icon: '<svg>…</svg>' } %}
      {% block content %}<p>Teaser text here.</p>{% endblock %}
    {% endembed %}
#}

{% set link_text = link_text|default(title) %}
{% set has_button = has_button|default(false) %}
{% set icon = icon|default('') %}

<div class="linked-section{{ has_button ? ' has-button' : '' }}">
    <div class="headline">
        <div class="icon">
            <figure class="icon-circle">
                {{ icon|raw }}
            </figure>
        </div>
        <h3 class="title">{{ title }}</h3>
    </div>
    <div class="content">
        {% block content %}{% endblock %}
    </div>
    <div class="link">
        <a href="{{ href }}" class="btn{{ has_button ? ' btn-gold' : ' btn-link' }}">
            {% if not has_button %}
                {# Phosphor caret-right-bold #}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor"><path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/></svg>
            {% endif %}
            {{ link_text }}
        </a>
    </div>
</div>
